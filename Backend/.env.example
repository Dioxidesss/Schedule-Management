# Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=

# Supabase anon/public key (safe to use client-side)
SUPABASE_ANON_KEY=

# Supabase service role key (server-side only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret from Supabase Dashboard > Project Settings > API > JWT Secret
SUPABASE_JWT_SECRET=

# Comma-separated list of allowed CORS origins for the React frontend
# e.g. http://localhost:5173,https://isomer.vercel.app
ALLOWED_ORIGINS=http://localhost:5173
